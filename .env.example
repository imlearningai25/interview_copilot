# ════════════════════════════════════════════════════════════════
#  Interview Copilot — environment variables
#  Copy this file to .env and fill in your values.
#  .env is gitignored — never commit it.
# ════════════════════════════════════════════════════════════════

# ── AI (required) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Copilot desktop app ───────────────────────────────────────
# Claude model to use for interview answers
#   fast/cheap  → claude-haiku-4-5-20251001
#   better      → claude-sonnet-4-6
COPILOT_MODEL=claude-haiku-4-5-20251001

# Default role shown in the overlay header (overridden by active job from API)
COPILOT_ROLE=Principal Software Engineer

# Speech recognition locale
COPILOT_LANGUAGE=en-US

# Microphone sensitivity (300–4000; lower = picks up quieter sounds)
COPILOT_ENERGY_THRESHOLD=300

# Seconds of silence before a phrase is considered complete and sent to AI
COPILOT_PAUSE_THRESHOLD=1.2

# Seconds to mute the mic after an answer is shown (prevents your voice
# reading the answer from being picked up as a new question)
COPILOT_ANSWER_COOLDOWN=25

# Overlay appearance
COPILOT_OPACITY=0.94
COPILOT_WIDTH=500
COPILOT_HEIGHT=420
COPILOT_FONT_SIZE=11
COPILOT_THEME=dark
COPILOT_ALWAYS_ON_TOP=true

# URL of the web app API (used to fetch the active job config)
COPILOT_API_URL=http://localhost:4001

# ── Web app — PostgreSQL ──────────────────────────────────────
POSTGRES_USER=copilot
POSTGRES_PASSWORD=copilot_dev
POSTGRES_DB=copilot_db

# ── Web app — Backend (FastAPI) ───────────────────────────────
DATABASE_URL=postgresql://copilot:copilot_dev@localhost:4000/copilot_db
CORS_ORIGINS=http://localhost:4002,http://localhost:80
ENVIRONMENT=development
BACKEND_PORT=4001

# ── Web app — Frontend (React/Vite) ──────────────────────────
VITE_API_URL=http://localhost:4001
FRONTEND_PORT=4002

# ── Legacy job setup app ──────────────────────────────────────
JOB_SETUP_PORT=4003

# ════════════════════════════════════════════════════════════════
#  Production overrides — set these in CI/CD or Secret Manager
# ════════════════════════════════════════════════════════════════
# ANTHROPIC_API_KEY=sk-ant-...
# DATABASE_URL=postgresql://user:pass@cloud-sql/copilot_db
# CORS_ORIGINS=https://yourdomain.com
# ENVIRONMENT=production
# VITE_API_URL=https://api.yourdomain.com
# COPILOT_API_URL=https://api.yourdomain.com
