# Secrets / local config
.env
job_config.json

# Python
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/

# Logs
*.log
copilot.log

# Vosk models — large binary files, download separately
vosk-model-*/

# Voice enrollment — personal biometric data, never commit
user_voice.npy

# Session history — contains interview Q&A, keep local
sessions/

# Frontend
frontend/node_modules/

# Terraform — state and tfvars contain secrets in plain text, never commit them
terraform/.terraform/
terraform/terraform.tfvars
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/*.tfplan
terraform/crash.log
# NOTE: terraform/.terraform.lock.hcl SHOULD be committed (locks provider versions)

# Claude Code project settings (local permissions, not portable)
.claude/
interview_copilot/*.*
